---
import Layout from '../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/translations';
import homepageData from '../data/homepage.json';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Load from JSON data file (updated by Publisher agent)
const { heroStory, topStories = [], moreNews = [], trending = [] } = homepageData;

// Fallback data for sections not yet in homepage.json
const opinionPieces = [
  { title: "Why Ireland Needs to Rethink Housing Policy", author: "Cormac Ó Suilleabháin" },
  { title: "The Future of Irish in Our Schools", author: "Máire Brennan" },
  { title: "Climate Action: Time for Bold Moves", author: "Eoin Murphy" },
];

const cultureStories = [
  { title: "New Irish Film Premieres at Festival", category: "Film" },
  { title: "Poet Wins Prestigious Literary Award", category: "Books" },
  { title: "Street Art Transforms Dublin Laneway", category: "Art" },
];
---

<Layout title="Home" description="Irish Ledger - Your daily source for Irish news, culture, sport, and games">
  <div class="two-column-layout">

    <!-- Main Column (3/4) -->
    <div class="main-column">

      <!-- Hero Story -->
      <article class="hero-cell">
        <a href={`/articles/${heroStory.slug}`} class="hero-image-link">
          <img src={heroStory.image} alt="" class="hero-image" />
        </a>
        <div class="hero-content">
          <span class="category-tag">{heroStory.category}</span>
          <h1><a href={`/articles/${heroStory.slug}`}>{heroStory.title}</a></h1>
          <p class="hero-summary">{heroStory.summary}</p>
          <div class="meta">
            <span class="author">By {heroStory.author}</span>
            <span class="time">{heroStory.time}</span>
          </div>
        </div>
      </article>

      <!-- Top Stories Row -->
      <div class="stories-row">
        {topStories.map(story => (
          <article class="story-card">
            <a href={`/articles/${story.slug}`}>
              <img src={story.image} alt="" />
            </a>
            <div class="story-content">
              <span class="category-tag small">{story.category}</span>
              <h3><a href={`/articles/${story.slug}`}>{story.title}</a></h3>
              <span class="time">{story.time}</span>
            </div>
          </article>
        ))}
      </div>

      <!-- Opinion Section (Coming Soon) -->
      <section class="section-cell coming-soon-section">
        <h2 class="section-title">{t('section.opinion')} <span class="coming-soon-badge">Coming Soon</span></h2>
        <div class="opinion-grid">
          {opinionPieces.map(piece => (
            <article class="opinion-item placeholder">
              <h3>{piece.title}</h3>
              <span class="author">{piece.author}</span>
            </article>
          ))}
        </div>
      </section>

      <!-- More News -->
      <section class="section-cell">
        <h2 class="section-title">{t('section.moreNews')}</h2>
        <ul class="news-list">
          {moreNews.map(story => (
            <li>
              <a href={`/articles/${story.slug}`}>
                <span class="news-title">{story.title}</span>
                <span class="time">{story.time}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <!-- Culture Section (Coming Soon) -->
      <section class="section-cell coming-soon-section">
        <h2 class="section-title">{t('section.culture')} <span class="coming-soon-badge">Coming Soon</span></h2>
        <div class="culture-grid">
          {cultureStories.map(story => (
            <article class="culture-item placeholder">
              <span class="culture-category">{story.category}</span>
              <h3>{story.title}</h3>
            </article>
          ))}
        </div>
      </section>

    </div>

    <!-- Sidebar (1/4) -->
    <aside class="sidebar">

      <!-- Games Module -->
      <div class="sidebar-module games-module">
        <h3 class="module-title">{t('section.games')}</h3>
        <a href="/craicle" class="game-card">
          <span class="game-icon">🟩</span>
          <div>
            <span class="game-name">{t('games.craicle')}</span>
            <span class="game-desc">{t('games.craicleDesc')}</span>
          </div>
        </a>
        <a href="/games" class="game-card">
          <span class="game-icon">🃏</span>
          <div>
            <span class="game-name">{t('games.moreGames')}</span>
            <span class="game-desc">{t('games.comingSoon')}</span>
          </div>
        </a>
      </div>

      <!-- Trending -->
      <div class="sidebar-module">
        <h3 class="module-title">{t('section.trending')}</h3>
        <ol class="trending-list">
          {trending.map((story, i) => (
            <li>
              <a href={story.slug ? `/articles/${story.slug}` : '#'}>
                <span class="trending-num">{i + 1}</span>
                <div>
                  <span class="trending-category">{story.category}</span>
                  <span class="trending-title">{story.title}</span>
                </div>
              </a>
            </li>
          ))}
        </ol>
      </div>

      <!-- Newsletter Signup -->
      <div class="sidebar-module newsletter-module">
        <h3 class="module-title">Newsletter</h3>
        <p>Get the best of Irish Ledger delivered daily.</p>
        <form class="newsletter-form">
          <input type="email" placeholder="Your email" />
          <button type="submit">Sign Up</button>
        </form>
      </div>

    </aside>

  </div>
</Layout>

<style>
  /* Two Column Layout */
  .two-column-layout {
    display: grid;
    grid-template-columns: 3fr 1fr;
    gap: 2rem;
  }

  /* Main Column */
  .main-column {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Hero Cell */
  .hero-cell {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1.5rem;
  }

  .hero-image {
    width: 100%;
    height: 400px;
    object-fit: cover;
  }

  .hero-content {
    padding-top: 1rem;
  }

  .category-tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .category-tag.small {
    font-size: 0.7rem;
  }

  .hero-content h1 {
    font-family: var(--font-serif);
    font-size: 2rem;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .hero-content h1 a:hover {
    text-decoration: underline;
  }

  .hero-summary {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .meta {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .meta .author {
    font-weight: 600;
  }

  .meta .time::before {
    content: "·";
    margin: 0 0.5rem;
  }

  /* Stories Row */
  .stories-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1.5rem;
  }

  .story-card img {
    width: 100%;
    height: 140px;
    object-fit: cover;
  }

  .story-content {
    padding-top: 0.75rem;
  }

  .story-card h3 {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.3;
    margin-top: 0.25rem;
  }

  .story-card .time {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }

  /* Section Cells */
  .section-cell {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1.5rem;
  }

  .section-title {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding-bottom: 0.5rem;
    margin-bottom: 1rem;
    border-bottom: 2px solid var(--color-primary);
  }

  /* Opinion Grid */
  .opinion-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .opinion-item h3 {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  .opinion-item .author {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  /* News List */
  .news-list {
    list-style: none;
  }

  .news-list li {
    border-bottom: 1px solid var(--color-border);
  }

  .news-list li:last-child {
    border-bottom: none;
  }

  .news-list a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 0;
  }

  .news-title {
    font-weight: 600;
  }

  .time {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  /* Culture Grid */
  .culture-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .culture-item h3 {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.3;
  }

  .culture-category {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  /* Coming Soon Placeholders */
  .coming-soon-section {
    opacity: 0.6;
  }

  .coming-soon-badge {
    font-size: 0.6rem;
    background: var(--color-accent);
    color: white;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    margin-left: 0.5rem;
    vertical-align: middle;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .placeholder h3 {
    color: var(--color-text-secondary);
  }

  /* Sidebar */
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar-module {
    border: 1px solid var(--color-border);
    padding: 1rem;
  }

  .module-title {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding-bottom: 0.5rem;
    margin-bottom: 1rem;
    border-bottom: 2px solid var(--color-primary);
  }

  /* Games Module */
  .games-module {
    background: var(--color-bg-alt);
    border: none;
  }

  .game-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem;
    background: white;
    border: 1px solid var(--color-border);
    margin-bottom: 0.5rem;
    transition: border-color 0.2s;
  }

  .game-card:last-child {
    margin-bottom: 0;
  }

  .game-card:hover {
    text-decoration: none;
    border-color: var(--color-accent);
  }

  .game-icon {
    font-size: 1.5rem;
  }

  .game-name {
    display: block;
    font-weight: 700;
  }

  .game-desc {
    display: block;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  /* Trending */
  .trending-list {
    list-style: none;
  }

  .trending-list li {
    padding-bottom: 0.75rem;
    margin-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .trending-list li:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .trending-list a {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .trending-num {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: #ccc;
    line-height: 1;
    min-width: 1.5rem;
  }

  .trending-category {
    display: block;
    font-size: 0.65rem;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 600;
  }

  .trending-title {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    line-height: 1.3;
  }

  /* Newsletter */
  .newsletter-module p {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .newsletter-form input {
    padding: 0.6rem;
    border: 1px solid var(--color-border);
    font-size: 0.9rem;
  }

  .newsletter-form button {
    padding: 0.6rem;
    background: var(--color-primary);
    color: white;
    border: none;
    font-weight: 600;
    cursor: pointer;
  }

  .newsletter-form button:hover {
    opacity: 0.9;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .two-column-layout {
      grid-template-columns: 1fr;
    }

    .sidebar {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .newsletter-module {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .stories-row,
    .opinion-grid,
    .culture-grid {
      grid-template-columns: 1fr;
    }

    .hero-image {
      height: 250px;
    }

    .hero-content h1 {
      font-size: 1.5rem;
    }

    .sidebar {
      grid-template-columns: 1fr;
    }

    .newsletter-module {
      grid-column: span 1;
    }
  }
</style>
