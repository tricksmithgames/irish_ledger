---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home" description="Irish Ledger - Your daily dose of Irish news, culture, and games">
  <section class="hero">
    <h1>Irish Ledger</h1>
    <p>Your daily dose of Irish news, culture, and craic</p>
  </section>

  <section class="features">
    <div class="feature">
      <h2>📰 News</h2>
      <p>Stories from Ireland and the diaspora worldwide</p>
    </div>
    <div class="feature">
      <h2>🎮 Craicle</h2>
      <p>Daily word game - coming soon!</p>
      <a href="/craicle" class="btn">Play Now</a>
    </div>
    <div class="feature">
      <h2>🇮🇪 Bilingual</h2>
      <p>Content in English and Gaeilge</p>
    </div>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 0;
    background: linear-gradient(135deg, #1a5f2a22, #ff8c0022);
    border-radius: 1rem;
    margin-bottom: 3rem;
  }

  .hero h1 {
    font-size: 3rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .hero p {
    font-size: 1.25rem;
    color: #666;
  }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .feature {
    background: white;
    padding: 2rem;
    border-radius: 1rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    text-align: center;
  }

  .feature h2 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .feature p {
    color: #666;
    margin-bottom: 1rem;
  }

  .btn {
    display: inline-block;
    background: var(--color-primary);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
  }

  .btn:hover {
    opacity: 0.9;
  }
</style>
