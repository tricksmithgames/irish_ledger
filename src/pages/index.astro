---
import Layout from '../layouts/Layout.astro';

// Placeholder data - would come from CMS/database
const heroStory = {
  title: "Historic Agreement Reached on Irish Language Act",
  summary: "Cross-party support sees landmark legislation pass after decades of campaigning by language advocates across the island.",
  image: "https://images.unsplash.com/photo-1590089415225-401ed6f9db8e?w=1200&h=600&fit=crop",
  category: "News",
  author: "Síle Ní Bhriain",
  time: "2 hours ago"
};

const trending = [
  { title: "GAA Championship: Dublin vs Kerry Preview", category: "Sport" },
  { title: "Traditional Music Festival Returns to Doolin", category: "Culture" },
  { title: "Irish Tech Startup Raises €50M in Funding", category: "Business" },
  { title: "New Exhibit Opens at National Gallery", category: "Culture" },
  { title: "Weather: Atlantic Storm Approaching", category: "News" },
];

const secondaryStories = [
  {
    title: "Diaspora Voices: Life in Boston's Irish Community",
    image: "https://images.unsplash.com/photo-1501594907352-04cda38ebc29?w=400&h=250&fit=crop",
    category: "Diaspora",
    time: "4 hours ago"
  },
  {
    title: "The Revival of Sean-nós Dancing",
    image: "https://images.unsplash.com/photo-1504609773096-104ff2c73ba4?w=400&h=250&fit=crop",
    category: "Culture",
    time: "5 hours ago"
  },
  {
    title: "Rural Ireland: Challenges Facing Small Towns",
    image: "https://images.unsplash.com/photo-1590089415225-401ed6f9db8e?w=400&h=250&fit=crop",
    category: "News",
    time: "6 hours ago"
  },
  {
    title: "Irish Athletes Prepare for Championships",
    image: "https://images.unsplash.com/photo-1461896836934- voices-01a80feab?w=400&h=250&fit=crop",
    category: "Sport",
    time: "7 hours ago"
  },
];

const opinionPieces = [
  { title: "Why Ireland Needs to Rethink Housing Policy", author: "Cormac Ó Suilleabháin" },
  { title: "The Future of Irish in Our Schools", author: "Máire Brennan" },
  { title: "Climate Action: Time for Bold Moves", author: "Eoin Murphy" },
];

const cultureStories = [
  { title: "New Irish Film Premieres at Festival", category: "Film" },
  { title: "Poet Wins Prestigious Literary Award", category: "Books" },
  { title: "Street Art Transforms Dublin Laneway", category: "Art" },
];
---

<Layout title="Home" description="Irish Ledger - Your daily source for Irish news, culture, sport, and games">
  <div class="homepage">

    <!-- Hero Section -->
    <section class="hero-section">
      <article class="hero-story">
        <a href="/news/hero-story">
          <img src={heroStory.image} alt="" class="hero-image" />
        </a>
        <div class="hero-content">
          <span class="category-tag">{heroStory.category}</span>
          <h1><a href="/news/hero-story">{heroStory.title}</a></h1>
          <p class="hero-summary">{heroStory.summary}</p>
          <div class="hero-meta">
            <span class="author">By {heroStory.author}</span>
            <span class="time">{heroStory.time}</span>
          </div>
        </div>
      </article>

      <aside class="trending-sidebar">
        <h3 class="sidebar-title">Trending</h3>
        <ol class="trending-list">
          {trending.map((story, i) => (
            <li>
              <a href="#">
                <span class="trending-num">{i + 1}</span>
                <div>
                  <span class="trending-category">{story.category}</span>
                  <span class="trending-title">{story.title}</span>
                </div>
              </a>
            </li>
          ))}
        </ol>
      </aside>
    </section>

    <!-- Secondary Stories Grid -->
    <section class="secondary-stories">
      {secondaryStories.map(story => (
        <article class="story-card">
          <a href="#">
            <img src={story.image} alt="" />
          </a>
          <div class="story-card-content">
            <span class="category-tag small">{story.category}</span>
            <h3><a href="#">{story.title}</a></h3>
            <span class="time">{story.time}</span>
          </div>
        </article>
      ))}
    </section>

    <!-- Section Modules -->
    <section class="section-modules">

      <!-- Opinion -->
      <div class="module">
        <h3 class="module-title">Opinion</h3>
        <ul class="module-list">
          {opinionPieces.map(piece => (
            <li>
              <a href="#">
                <span class="opinion-title">{piece.title}</span>
                <span class="opinion-author">{piece.author}</span>
              </a>
            </li>
          ))}
        </ul>
        <a href="/opinion" class="module-link">More Opinion →</a>
      </div>

      <!-- Culture -->
      <div class="module">
        <h3 class="module-title">Culture</h3>
        <ul class="module-list">
          {cultureStories.map(story => (
            <li>
              <a href="#">
                <span class="culture-category">{story.category}</span>
                <span class="culture-title">{story.title}</span>
              </a>
            </li>
          ))}
        </ul>
        <a href="/culture" class="module-link">More Culture →</a>
      </div>

      <!-- Games Module -->
      <div class="module games-module">
        <h3 class="module-title">Games</h3>
        <div class="games-promo">
          <a href="/craicle" class="game-card">
            <span class="game-icon">🟩</span>
            <div>
              <span class="game-name">Craicle</span>
              <span class="game-desc">Daily word game</span>
            </div>
          </a>
          <a href="/games" class="game-card">
            <span class="game-icon">🃏</span>
            <div>
              <span class="game-name">More Games</span>
              <span class="game-desc">Coming soon</span>
            </div>
          </a>
        </div>
      </div>

    </section>

    <!-- More News -->
    <section class="more-news">
      <h3 class="section-title">More News</h3>
      <div class="news-list">
        <article class="news-item">
          <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=150&h=100&fit=crop" alt="" />
          <div>
            <h4><a href="#">Government Announces New Infrastructure Plan</a></h4>
            <span class="time">8 hours ago</span>
          </div>
        </article>
        <article class="news-item">
          <img src="https://images.unsplash.com/photo-1551836022-deb4988cc6c0?w=150&h=100&fit=crop" alt="" />
          <div>
            <h4><a href="#">Cork Harbour Development Gets Green Light</a></h4>
            <span class="time">10 hours ago</span>
          </div>
        </article>
        <article class="news-item">
          <img src="https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?w=150&h=100&fit=crop" alt="" />
          <div>
            <h4><a href="#">Irish Scientists Make Breakthrough Discovery</a></h4>
            <span class="time">12 hours ago</span>
          </div>
        </article>
      </div>
    </section>

  </div>
</Layout>

<style>
  .homepage {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* Hero Section */
  .hero-section {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 1.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .hero-story {
    display: flex;
    flex-direction: column;
  }

  .hero-image {
    width: 100%;
    height: 400px;
    object-fit: cover;
  }

  .hero-content {
    padding-top: 1rem;
  }

  .category-tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .category-tag.small {
    font-size: 0.7rem;
  }

  .hero-content h1 {
    font-family: var(--font-serif);
    font-size: 2rem;
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .hero-content h1 a:hover {
    text-decoration: underline;
  }

  .hero-summary {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }

  .hero-meta {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .hero-meta .author {
    font-weight: 600;
  }

  .hero-meta .time::before {
    content: "·";
    margin: 0 0.5rem;
  }

  /* Trending Sidebar */
  .trending-sidebar {
    border-left: 1px solid var(--color-border);
    padding-left: 1.5rem;
  }

  .sidebar-title {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-primary);
  }

  .trending-list {
    list-style: none;
  }

  .trending-list li {
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .trending-list li:last-child {
    border-bottom: none;
  }

  .trending-list a {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .trending-num {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: #ccc;
    line-height: 1;
  }

  .trending-category {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 600;
  }

  .trending-title {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.3;
  }

  /* Secondary Stories */
  .secondary-stories {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .story-card img {
    width: 100%;
    height: 150px;
    object-fit: cover;
  }

  .story-card-content {
    padding-top: 0.75rem;
  }

  .story-card h3 {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.3;
    margin-top: 0.25rem;
  }

  .story-card .time {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }

  /* Section Modules */
  .section-modules {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .module-title {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding-bottom: 0.5rem;
    margin-bottom: 1rem;
    border-bottom: 2px solid var(--color-primary);
  }

  .module-list {
    list-style: none;
  }

  .module-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .module-list a {
    display: block;
  }

  .opinion-title {
    display: block;
    font-family: var(--font-serif);
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.25rem;
  }

  .opinion-author {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .culture-category {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 600;
  }

  .culture-title {
    display: block;
    font-weight: 600;
  }

  .module-link {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  /* Games Module */
  .games-module {
    background: var(--color-bg-alt);
    padding: 1rem;
    border-radius: 4px;
  }

  .games-promo {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .game-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem;
    background: white;
    border-radius: 4px;
    border: 1px solid var(--color-border);
    transition: border-color 0.2s;
  }

  .game-card:hover {
    text-decoration: none;
    border-color: var(--color-accent);
  }

  .game-icon {
    font-size: 1.5rem;
  }

  .game-name {
    display: block;
    font-weight: 700;
  }

  .game-desc {
    display: block;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  /* More News */
  .section-title {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding-bottom: 0.5rem;
    margin-bottom: 1rem;
    border-bottom: 2px solid var(--color-primary);
  }

  .news-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .news-item {
    display: flex;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .news-item img {
    width: 120px;
    height: 80px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .news-item h4 {
    font-family: var(--font-serif);
    font-size: 1rem;
    line-height: 1.3;
    margin-bottom: 0.25rem;
  }

  .news-item .time {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .hero-section {
      grid-template-columns: 1fr;
    }

    .trending-sidebar {
      border-left: none;
      border-top: 1px solid var(--color-border);
      padding-left: 0;
      padding-top: 1.5rem;
    }

    .trending-list {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .secondary-stories {
      grid-template-columns: repeat(2, 1fr);
    }

    .section-modules {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .hero-image {
      height: 250px;
    }

    .hero-content h1 {
      font-size: 1.5rem;
    }

    .secondary-stories {
      grid-template-columns: 1fr;
    }

    .trending-list {
      grid-template-columns: 1fr;
    }
  }
</style>
