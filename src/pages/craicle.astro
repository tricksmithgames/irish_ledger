---
import Layout from '../layouts/Layout.astro';
// import CraicleGame from '../components/CraicleGame'; // React component - coming soon
---

<Layout title="Craicle" description="Daily Irish word game - test your vocabulary!">
  <section class="craicle-page">
    <h1>Craicle</h1>
    <p class="subtitle">The daily Irish word game</p>

    <div class="game-container">
      <!-- This will be a React island -->
      <p class="coming-soon">🎮 Game coming soon!</p>
      <p>Guess the 5-letter word in 6 tries.</p>
    </div>

    <div class="rules">
      <h2>How to Play</h2>
      <ul>
        <li>Guess the word in 6 tries</li>
        <li>Each guess must be a valid 5-letter word</li>
        <li>🟩 Green = correct letter, correct spot</li>
        <li>🟨 Yellow = correct letter, wrong spot</li>
        <li>⬜ Gray = letter not in word</li>
      </ul>
    </div>
  </section>
</Layout>

<style>
  .craicle-page {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  h1 {
    font-size: 2.5rem;
    color: var(--color-primary);
  }

  .subtitle {
    color: #666;
    margin-bottom: 2rem;
  }

  .game-container {
    background: white;
    padding: 3rem;
    border-radius: 1rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    margin-bottom: 2rem;
  }

  .coming-soon {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .rules {
    text-align: left;
    background: #f5f5f5;
    padding: 1.5rem;
    border-radius: 0.5rem;
  }

  .rules h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
  }

  .rules ul {
    margin-left: 1.5rem;
  }

  .rules li {
    margin-bottom: 0.5rem;
  }
</style>
