---
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { getLangFromUrl, useTranslations, getLocalePath } from '../i18n/translations';

interface Props {
  title: string;
  description?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { title, description = t('site.description') } = Astro.props;
const today = new Date().toLocaleDateString(lang === 'ga' ? 'ga-IE' : 'en-IE', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const p = (path: string) => getLocalePath(lang, path);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Source+Sans+3:wght@400;600;700&display=swap" rel="stylesheet">
    <title>{title} | {t('site.title')}</title>
  </head>
  <body>
    <!-- Top Bar -->
    <div class="top-bar">
      <div class="top-bar-inner">
        <span class="date">{today}</span>
        <div class="top-bar-center">
          <LanguageSwitcher />
        </div>
        <div class="top-bar-right">
          <a href={p('/games')}>{t('topbar.todaysGames')}</a>
          <a href={p('/subscribe')} class="subscribe-btn">{t('topbar.subscribe')}</a>
        </div>
      </div>
    </div>

    <!-- Masthead -->
    <header class="masthead">
      <a href={p('/')} class="logo">{t('site.title')}</a>
      {lang === 'ga' && <p class="subtitle">{t('site.subtitle')}</p>}
      <p class="tagline">{t('site.tagline')}</p>
    </header>

    <!-- Main Navigation -->
    <nav class="main-nav">
      <div class="nav-inner">
        <ul>
          <li><a href={p('/')}>{t('nav.home')}</a></li>
          <li><a href={p('/news')}>{t('nav.news')}</a></li>
          <li><a href={p('/culture')}>{t('nav.culture')}</a></li>
          <li><a href={p('/sport')}>{t('nav.sport')}</a></li>
          <li><a href={p('/diaspora')}>{t('nav.diaspora')}</a></li>
          <li><a href={p('/opinion')}>{t('nav.opinion')}</a></li>
          <li><a href={p('/games')} class="games-link">{t('nav.games')}</a></li>
        </ul>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-section">
          <h4>{t('footer.sections')}</h4>
          <ul>
            <li><a href={p('/news')}>{t('nav.news')}</a></li>
            <li><a href={p('/culture')}>{t('nav.culture')}</a></li>
            <li><a href={p('/sport')}>{t('nav.sport')}</a></li>
            <li><a href={p('/opinion')}>{t('nav.opinion')}</a></li>
          </ul>
        </div>
        <div class="footer-section">
          <h4>{t('footer.more')}</h4>
          <ul>
            <li><a href={p('/games')}>{t('nav.games')}</a></li>
            <li><a href={p('/diaspora')}>{t('nav.diaspora')}</a></li>
            <li><a href={p('/newsletter')}>{t('footer.newsletter')}</a></li>
          </ul>
        </div>
        <div class="footer-section">
          <h4>{t('footer.about')}</h4>
          <ul>
            <li><a href={p('/about')}>{t('footer.aboutUs')}</a></li>
            <li><a href={p('/contact')}>{t('footer.contact')}</a></li>
            <li><a href={p('/advertise')}>{t('footer.advertise')}</a></li>
            <li><a href={p('/privacy')}>{t('footer.privacy')}</a></li>
          </ul>
        </div>
        <div class="footer-section">
          <h4>{t('footer.connect')}</h4>
          <ul>
            <li><a href="#">Twitter/X</a></li>
            <li><a href="#">Facebook</a></li>
            <li><a href="#">Instagram</a></li>
            <li><a href="#">RSS</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>{t('footer.copyright', { year: new Date().getFullYear() })}</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --color-primary: #121212;
    --color-accent: #567b2e;
    --color-border: #e0e0e0;
    --color-bg: #ffffff;
    --color-bg-alt: #f7f7f7;
    --color-text: #121212;
    --color-text-secondary: #666666;
    --font-serif: 'Libre Baskerville', Georgia, serif;
    --font-sans: 'Source Sans 3', system-ui, sans-serif;
  }

  body {
    font-family: var(--font-sans);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.5;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  /* Top Bar */
  .top-bar {
    background: var(--color-primary);
    color: white;
    font-size: 0.8rem;
    padding: 0.5rem 0;
  }

  .top-bar-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .top-bar-center {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .top-bar-right {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .top-bar a {
    color: white;
  }

  .subscribe-btn {
    background: var(--color-accent);
    padding: 0.35rem 0.75rem;
    border-radius: 3px;
    font-weight: 600;
  }

  .subscribe-btn:hover {
    text-decoration: none;
    opacity: 0.9;
  }

  /* Masthead */
  .masthead {
    text-align: center;
    padding: 1.5rem 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .logo {
    font-family: var(--font-serif);
    font-size: 2.75rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: -0.02em;
  }

  .logo:hover {
    text-decoration: none;
  }

  .subtitle {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-style: italic;
    color: var(--color-text-secondary);
    margin-top: 0.25rem;
  }

  .tagline {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-top: 0.25rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* Main Nav */
  .main-nav {
    border-bottom: 2px solid var(--color-primary);
    position: sticky;
    top: 0;
    background: white;
    z-index: 100;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .main-nav ul {
    display: flex;
    justify-content: center;
    gap: 0.25rem;
    list-style: none;
    flex-wrap: wrap;
  }

  .main-nav a {
    display: block;
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    font-weight: 600;
    transition: background 0.2s;
  }

  .main-nav a:hover {
    background: var(--color-bg-alt);
    text-decoration: none;
  }

  .games-link {
    color: var(--color-accent) !important;
  }

  /* Main Content */
  main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem 1rem;
  }

  /* Footer */
  .site-footer {
    background: var(--color-primary);
    color: white;
    margin-top: 3rem;
    padding-top: 2.5rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 2rem;
  }

  .footer-section h4 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
    color: #999;
  }

  .footer-section ul {
    list-style: none;
  }

  .footer-section li {
    margin-bottom: 0.5rem;
  }

  .footer-section a {
    color: #ccc;
    font-size: 0.9rem;
  }

  .footer-section a:hover {
    color: white;
  }

  .footer-bottom {
    border-top: 1px solid #333;
    margin-top: 2rem;
    padding: 1.5rem 1rem;
    text-align: center;
    font-size: 0.8rem;
    color: #666;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .logo {
      font-size: 2rem;
    }

    .main-nav a {
      padding: 0.5rem 0.75rem;
      font-size: 0.85rem;
    }

    .top-bar .date {
      display: none;
    }

    .top-bar-center {
      position: static;
      transform: none;
    }

    .top-bar-inner {
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.5rem;
    }
  }
</style>
